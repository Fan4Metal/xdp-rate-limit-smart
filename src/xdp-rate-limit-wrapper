#!/usr/bin/env bash
set -euo pipefail

IFACE="${1:-}"
ACTION="${2:-}"
MODE="${XDP_MODE:-auto}"
OBJ="/usr/local/lib/xdp-rate-limit/xdp_rate_limit.bpf.o"
PIN_BASE="/sys/fs/bpf/xdp-rate-limit"
PIN_DIR="${PIN_BASE}/${IFACE}"
CONFIG="/etc/xdp-rate-limit/config.json"
LOADER="/usr/local/sbin/xdp-rate-loader"
DAEMON="/usr/local/sbin/xdp-rate-daemon"

if [[ -z "$IFACE" || -z "$ACTION" ]]; then
  echo "Usage: $0 IFACE start|stop" >&2
  exit 2
fi

mountpoint -q /sys/fs/bpf || mount -t bpf bpf /sys/fs/bpf
mkdir -p "$PIN_BASE"

case "$ACTION" in
  start)
    "$LOADER" load "$IFACE" "$OBJ" "$PIN_DIR" "$MODE"
    exec "$DAEMON" "$IFACE" --config "$CONFIG" --pin-dir "$PIN_DIR"
    ;;
  stop)
    "$LOADER" unload "$IFACE" "$PIN_DIR" || true
    ;;
  *)
    echo "Unknown action: $ACTION" >&2
    exit 2
    ;;
esac
